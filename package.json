{
  "name": "mfdoc",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "mfdoc": "./dist/cli/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "graph:image": "node scripts/graph-to-image.mjs",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "discovery": "tsx scripts/test-discovery.ts",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/node": "^25.0.6",
    "@types/semver": "^7.5.8",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.3.2",
    "commander": "^14.0.2",
    "glob": "^13.0.0",
    "picocolors": "^1.1.1",
    "semver": "^7.6.0",
    "yaml": "^2.8.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tiagocastro070/mfdoc.git"
  },
  "bugs": {
    "url": "https://github.com/tiagocastro070/mfdoc/issues"
  },
  "keywords": [
